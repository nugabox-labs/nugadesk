POSTGRES_USER=nugadesk
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=nugadesk

# Which Postgres the backend connects to. Leave both unset/commented to use
# the local `db` compose service (postgresql+psycopg://...@db:5432/...).
# To share one DB between local dev and the NAS deployment, point both at
# the NAS's externally published Postgres port instead:
DB_HOST=nugacloud.synology.me
DB_PORT=7097

SECRET_KEY=<CHANGE_ME_RANDOM_64_HEX>
AUTH_USERNAME=admin
AUTH_PASSWORD=<CHANGE_ME>
CORS_ORIGINS=http://localhost:5173,http://localhost:7090,https://work.nugabox.com

# iCloud CalDAV background sync (optional — defaults shown)
ICLOUD_POLL_ENABLED=true
ICLOUD_POLL_INTERVAL_SECONDS=300
ICLOUD_AUTO_SYNC_DEBOUNCE_SECONDS=3

# Sign in with Apple (웹). APPLE_CLIENT_ID가 비어 있으면 로그인 페이지에 버튼이 표시되지 않음.
# Apple Developer Services ID에 등록한 Return URL과 반드시 일치해야 함 (HTTPS + 도메인만 허용, localhost 불가).
# 예: Domain work.nugabox.com / Return URL https://work.nugabox.com/login
APPLE_CLIENT_ID=
APPLE_REDIRECT_URI=https://work.nugabox.com/login
